"""
 
import requests       # Fuer HTTP-Anfragen an die GDELT API
import json           # Fuer das Parsen der JSON-Antworten
from datetime import datetime, timezone   # Fuer die Datumsberechnung (UTC)
 
 
# ==============================================================================
# KONFIGURATION
# ==============================================================================
 
# Liste der Suchbegriffe (Buzzwords), nach denen die Nachrichten durchsucht werden.
# Jeder Begriff deckt einen anderen Aspekt des Wasserstoffmarktes ab:
#   - Preis- und Angebotssignale (z.B. Strompreise, Ueberschussstrom)
#   - Nachfrage- und Handelssignale (z.B. Importterminals, Handelsabkommen in Asien)
BUZZWORDS = [
    "green hydrogen import",          # Import von gruenem Wasserstoff
    "hydrogen economy Asia",          # Wasserstoffwirtschaft in Asien
    "electricity price hydrogen",     # Strompreise im Zusammenhang mit Wasserstoff
    "excess generation electrolyzer", # Ueberschussstrom fuer Elektrolyseure
    "hydrogen terminal Japan",        # Wasserstoff-Terminal in Japan
    "ammonia port Korea",             # Ammoniakhafen in Suedkorea
    "electrolyzer order Korea",       # Elektrolyseur-Bestellungen aus Korea
    "hydrogen plant Asia Pacific",    # Wasserstoffanlagen im asiatisch-pazifischen Raum
    "hydrogen MOU ministry",          # Absichtserklaerungen mit Ministerien
    "hydrogen trade deal",            # Wasserstoff-Handelsabkommen
    "renewable surplus hydrogen",     # Wasserstoff aus erneuerbarem Energieueberschuss
    "variable renewable hydrogen",    # Wasserstoff aus fluktuierenden Erneuerbaren
]
 
# Basis-URL der GDELT DOC 2.0 API.
# Diese API erlaubt die Volltextsuche in weltweiten Nachrichtenartikeln.
GDELT_DOC_API = "https://api.gdeltproject.org/api/v2/doc/doc"
 
 
# ==============================================================================
# HILFSFUNKTIONEN
# ==============================================================================
 
def today_date_str() -> str:
    """
    Gibt das heutige Datum als String im Format YYYYMMDD zurueck (UTC-Zeit).
 
    Begruendung fuer UTC: GDELT speichert alle Zeitstempel in UTC. Damit die
    Datumsfilterung korrekt funktioniert, muss auch die Anfrage in UTC erfolgen.
 
    Rueckgabe:
        str: z.B. "20250412" fuer den 12. April 2025
    """
    return datetime.now(timezone.utc).strftime("%Y%m%d")
 
 
def fetch_articles_for_keyword(keyword: str, max_records: int = 5) -> list[dict]:
    """
    Sendet eine Anfrage an die GDELT DOC 2.0 API fuer ein einzelnes Suchstichwort
    und gibt die gefundenen Artikel als Liste von Woerterbuechern zurueck.
 
    Die Suche wird auf den heutigen Tag (00:00:00 bis 23:59:59 UTC) beschraenkt,
    damit nur tagesaktuelle Nachrichten angezeigt werden.
 
    Fuer jeden gefundenen Artikel wird das Feld "matched_keyword" gesetzt,
    damit spaeter nachvollziehbar ist, durch welchen Suchbegriff der Artikel
    gefunden wurde.
 
    Parameter:
        keyword (str):      Der Suchbegriff, nach dem gesucht wird.
        max_records (int):  Maximale Anzahl Artikel pro Anfrage (Standard: 5).
 
    Rueckgabe:
        list[dict]: Liste der gefundenen Artikel. Jeder Artikel ist ein
                    Woerterbuch mit Feldern wie "title", "url", "domain",
                    "seendate" und "matched_keyword".
                    Bei einem Fehler wird eine leere Liste zurueckgegeben.
    """
    today = today_date_str()
 
    # API-Parameter gemaess GDELT DOC 2.0 Dokumentation
    params = {
        "query":         keyword,
        "mode":          "artlist",             # Gibt eine Liste von Artikeln zurueck
        "format":        "json",                # Antwort im JSON-Format
        "maxrecords":    max_records,           # Max. Anzahl Ergebnisse
        "startdatetime": f"{today}000000",      # Beginn: Mitternacht heute (UTC)
        "enddatetime":   f"{today}235959",      # Ende: 23:59:59 heute (UTC)
        "sort":          "DateDesc",            # Neueste Artikel zuerst
    }
 
    try:
        # HTTP GET-Anfrage mit 15 Sekunden Timeout
        response = requests.get(GDELT_DOC_API, params=params, timeout=15)
 
        # Wirft eine Ausnahme, falls der HTTP-Statuscode ein Fehler ist (4xx, 5xx)
        response.raise_for_status()
 
        data = response.json()
        articles = data.get("articles", [])  # Leere Liste, falls kein "articles"-Feld
 
        # Suchbegriff jedem Artikel als Zusatzfeld hinzufuegen
        for art in articles:
            art["matched_keyword"] = keyword
 
        return articles
 
    except requests.exceptions.HTTPError as e:
        # Tritt auf, wenn der Server einen Fehlerstatuscode zurueckgibt
        print(f"  [HTTP-Fehler] '{keyword}': {e}")
    except requests.exceptions.ConnectionError:
        # Tritt auf, wenn die Verbindung zum Server nicht hergestellt werden kann
        print(f"  [Verbindungsfehler] Keine Verbindung zu GDELT fuer '{keyword}'")
    except requests.exceptions.Timeout:
        # Tritt auf, wenn der Server nicht innerhalb von 15 Sekunden antwortet
        print(f"  [Timeout] Anfrage fuer '{keyword}' hat zu lange gedauert")
    except json.JSONDecodeError:
        # Tritt auf, wenn die Antwort kein gueltiges JSON enthaelt
        print(f"  [Parse-Fehler] Ungueltige JSON-Antwort fuer '{keyword}'")
 
    return []
 
 
def deduplicate(articles: list[dict]) -> list[dict]:
    """
    Entfernt doppelte Artikel aus der Gesamtliste anhand der URL.
 
    Da mehrere Suchbegriffe denselben Artikel finden koennen, muss sichergestellt
    werden, dass jeder Artikel nur einmal angezeigt wird. Als eindeutiger
    Schluessel wird die URL verwendet.
 
    Parameter:
        articles (list[dict]): Liste aller gesammelten Artikel (mit Duplikaten).
 
    Rueckgabe:
        list[dict]: Liste ohne Duplikate; die Reihenfolge des ersten Auftretens
                    bleibt erhalten.
    """
    seen_urls = set()   # Menge bereits gesehener URLs (fuer O(1)-Suche)
    unique = []
 
    for art in articles:
        url = art.get("url", "")
        if url and url not in seen_urls:
            seen_urls.add(url)
            unique.append(art)
 
    return unique
 
 
def score_article(article: dict) -> int:
    """
    Berechnet einen einfachen Relevanzwert fuer einen Artikel.
 
    Der Wert erhoert sich um 2 fuer jeden Suchbegriff aus BUZZWORDS, der im
    Titel des Artikels vorkommt. So werden Artikel, die mehrere relevante
    Themen ansprechen, hoeher gerankt und erscheinen weiter oben in der Ausgabe.
 
    Hintergrund: GDELT liefert Artikel bereits gefiltert nach dem Suchbegriff.
    Dieser Score hebt jedoch Artikel hervor, die thematisch besonders breit
    aufgestellt sind (z.B. gleichzeitig ueber Strompreise und Handelsdeal berichten).
 
    Parameter:
        article (dict): Ein Artikel-Woerterbuch mit mindestens dem Feld "title".
 
    Rueckgabe:
        int: Relevanzwert (0 = kein Treffer, hoehere Werte = relevanter).
    """
    title_text = article.get("title", "").lower()
    score = 0
    for kw in BUZZWORDS:
        if kw.lower() in title_text:
            score += 2
    return score
 
 
def print_report(articles: list[dict]) -> None:
    """
    Gibt den vollstaendigen Tagesbericht auf der Konsole aus.
 
    Der Bericht besteht aus zwei Teilen:
      1. Artikelliste: Alle gefundenen Artikel sortiert nach Relevanz, mit
         Titel, Quelle, Uhrzeit, Suchbegriff und URL.
      2. Produktionssignal: Eine Auswertung, ob heute ein guenstiger Zeitpunkt
         fuer die Wasserstoffproduktion vorliegt, basierend auf den erkannten
         Kategorien von Suchbegriffen.
 
    Signallogik:
      - Preis-/Angebotssignale: Buzzwords, die auf niedrige Strompreise oder
        Energieueberschuss hinweisen.
      - Nachfragesignale: Buzzwords, die auf asiatische Importnachfrage hinweisen.
 
    Parameter:
        articles (list[dict]): Deduplizierte, tagesaktuelle Artikelliste.
    """
    today_str = datetime.now(timezone.utc).strftime("%A, %d %B %Y")
    separator = "=" * 70
 
    # --- Kopfzeile ---
    print(separator)
    print("  HYDROGEN MARKET NEWS - AUSTRALIA PRODUCTION SIGNAL")
    print(f"  {today_str} (UTC)  |  {len(articles)} unique articles found")
    print(separator)
 
    # Falls keine Artikel gefunden wurden, Hinweis ausgeben und abbrechen
    if not articles:
        print("\n  No relevant hydrogen news found for today. Try again later.\n")
        return
 
    # Artikel nach Relevanzwert (absteigend) und Datum sortieren
    articles.sort(key=lambda a: (score_article(a), a.get("seendate", "")), reverse=True)
 
    # --- Artikelliste ---
    for i, art in enumerate(articles, start=1):
        title     = art.get("title", "No title")
        url       = art.get("url", "N/A")
        source    = art.get("domain", "Unknown source")
        seendate  = art.get("seendate", "")
        keyword   = art.get("matched_keyword", "")
        relevance = score_article(art)
 
        # GDELT-Zeitstempel hat das Format YYYYMMDDTHHmmssZ
        try:
            dt = datetime.strptime(seendate, "%Y%m%dT%H%M%SZ")
            time_str = dt.strftime("%H:%M UTC")
        except (ValueError, TypeError):
            time_str = seendate  # Rohdaten ausgeben, falls Format unbekannt
 
        print(f"\n  [{i:02d}] {title}")
        print(f"       Source  : {source}  |  {time_str}")
        print(f"       Keyword : {keyword}")
        if relevance > 2:
            # Nur anzeigen, wenn mehr als ein Suchbegriff im Titel vorkommt
            print(f"       Cross-topic relevance score: {relevance}")
        print(f"       URL     : {url}")
 
    # --- Produktionssignal ---
    print("\n" + separator)
    print("  PRODUCTION SIGNAL SUMMARY")
    print(separator)
 
    # Welche Suchbegriffe haben heute Artikel geliefert?
    keywords_found = set(a.get("matched_keyword") for a in articles)
 
    # Gruppe 1: Begriffe, die auf guenstige Produktionsbedingungen hinweisen
    # (niedrige Strompreise, Energieueberschuss, erneuerbare Varianzen)
    price_kws = {
        "electricity price hydrogen",
        "excess generation electrolyzer",
        "renewable surplus hydrogen",
        "variable renewable hydrogen",
    }
 
    # Gruppe 2: Begriffe, die auf Nachfrage aus dem asiatischen Markt hinweisen
    # (Importterminals, Handelsabkommen, Ministervereinbarungen)
    demand_kws = {
        "hydrogen terminal Japan",
        "ammonia port Korea",
        "electrolyzer order Korea",
        "hydrogen trade deal",
        "hydrogen MOU ministry",
    }
 
    # Anzahl der Treffer je Gruppe bestimmen (Schnittmenge mit gefundenen Keywords)
    price_signals  = len(keywords_found & price_kws)
    demand_signals = len(keywords_found & demand_kws)
 
    print(f"\n  Price/supply keywords matched : {price_signals} / {len(price_kws)}")
    print(f"  Demand/trade keywords matched : {demand_signals} / {len(demand_kws)}")
 
    # Produktionssignal ausgeben: schwellenwertbasierte Entscheidungslogik
    if price_signals >= 2:
        print("\n  SIGNAL: FAVOURABLE - Multiple low-price / surplus-energy")
        print("  indicators detected. Consider scheduling electrolyzer runs.")
    elif price_signals == 1:
        print("\n  SIGNAL: MODERATE - Some price/surplus indicators present.")
        print("  Monitor spot prices before committing to production.")
    else:
        print("\n  SIGNAL: LOW - No clear electricity-price signals today.")
        print("  Defer hydrogen production until conditions improve.")
 
    # Nachfragesignal ausgeben
    if demand_signals >= 2:
        print("\n  EXPORT DEMAND: Strong - Asian market activity detected.")
    elif demand_signals == 1:
        print("\n  EXPORT DEMAND: Moderate - Some Asian market interest.")
    else:
        print("\n  EXPORT DEMAND: Quiet - Little Asian market news today.")
 
    print("\n" + separator + "\n")
 
 
# ==============================================================================
# HAUPTPROGRAMM
# ==============================================================================
 
def main():
    """
    Einstiegspunkt des Skripts.
 
    Ablauf:
      1. Fuer jeden Suchbegriff in BUZZWORDS wird eine separate API-Anfrage
         an GDELT gestellt.
      2. Alle gefundenen Artikel werden gesammelt und dedupliziert.
      3. Der Tagesbericht mit Artikelliste und Produktionssignal wird ausgegeben.
    """
    print("\nFetching today's hydrogen news from GDELT ...\n")
 
    all_articles: list[dict] = []
 
    # Jeden Suchbegriff einzeln abfragen und Ergebnisse sammeln
    for kw in BUZZWORDS:
        print(f"  Searching: \"{kw}\" ...")
        results = fetch_articles_for_keyword(kw, max_records=5)
        print(f"             -> {len(results)} article(s) found")
        all_articles.extend(results)
 
    # Duplikate entfernen
    unique_articles = deduplicate(all_articles)
    print(f"\n  Total unique articles after deduplication: {len(unique_articles)}\n")
 
    # Bericht ausgeben
    print_report(unique_articles)
 
 
# Dieses Skript wird nur ausgefuehrt, wenn es direkt gestartet wird
# (nicht wenn es als Modul in ein anderes Skript importiert wird).
if __name__ == "__main__":
    main()
